# ── Database ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/letslink
DATABASE_URL_SYNC=postgresql://postgres:YOUR_PASSWORD@localhost:5432/letslink

# ── JWT Secret ─────────────────────────────────────────
SECRET_KEY=generate-a-strong-random-key-here

# ── Razorpay ───────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret-here

# ── App Settings ───────────────────────────────────────
DEBUG=True
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:5500","http://localhost:5500"]

# ── Sentry (Error Tracking) ───────────────────────────
SENTRY_DSN=
